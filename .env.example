# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_QUEUE=aisoc_alerts

# LLM (Ollama) — OpenAI-совместимый API
OLLAMA_BASE_URL=http://localhost:11434/v1
SMALL_LLM_MODEL=smallm2:1.7b
LARGE_LLM_MODEL=luisppb16/gemma4-e4b-SecOps:latest 

# Wazuh Indexer (SIEM data source)
WAZUH_API_INDEXER_URL=https://localhost:9200
WAZUH_API_INDEXER_USER=admin
WAZUH_API_INDEXER_PASS=changeme
WAZUH_API_INDEXER_ALERT=wazuh-alerts-4.x-

# Wazuh Manager API (optional, для отправки планов)
WAZUH_API_URL=https://localhost:55000
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASS=changeme

# Connector
CONNECTOR_HOST=0.0.0.0
CONNECTOR_PORT=8000
USE_RABBITMQ=true

# Agent
AGENT_HOST=0.0.0.0
AGENT_PORT=8001
VERBOSE=true

# Chroma (Vector DB)
CHROMA_HOST=localhost
CHROMA_PORT=8002
CHROMA_COLLECTION=aisoc_playbooks
