# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_QUEUE=aisoc_alerts

# LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1
SMALL_LLM_MODEL=phi3:mini
LARGE_LLM_MODEL=llama3.1:8b

# OpenRouter (опционально, если Ollama недоступен)
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Wazuh (SIEM)
WAZUH_API_URL=http://localhost:55000
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASS=wazuh-wui

# Connector
CONNECTOR_HOST=0.0.0.0
CONNECTOR_PORT=8000
CONNECTOR_WEBHOOK_PATH=/webhook/wazuh

# Agent
AGENT_HOST=0.0.0.0
AGENT_PORT=8001

# Chroma (Vector DB)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=aisoc_playbooks
